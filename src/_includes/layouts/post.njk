---
layout: layouts/base.njk
---
<article class="section">
  <div class="container" style="max-width:46rem">
    <p><a href="{{ base }}{{ slugs.news }}/">← {{ t[lang].news.backToNews }}</a></p>
    <h1>{{ title }}</h1>
    <p class="post-meta">{{ t[lang].news.publishedOn }} <time datetime="{{ page.date | dateISO }}">{{ page.date | dateDisplay(lang) }}</time></p>
    {% if image %}<img src="{{ image }}" alt="{{ imageAlt or title }}" style="border-radius:14px;margin-block:1.5rem">{% endif %}
    {{ content | safe }}
  </div>
</article>
