<header class="site-header">
  <div class="container header-inner">
    <a class="brand" href="{{ base }}">
      <img src="/assets/img/icon-512.png" alt="" width="512" height="512">
      <span>
        <span class="brand-name">PANDAI</span>
        <span class="brand-tag">{{ t[lang].meta.tagline }}</span>
      </span>
    </a>

    <button class="nav-toggle" aria-expanded="false" aria-controls="main-nav">
      {{ t[lang].nav.menu }}
    </button>

    <nav id="main-nav" class="main-nav" aria-label="{{ t[lang].nav.mainNav }}">
      <ul>
        <li><a href="{{ base }}" {% if pageKey == "home" %}aria-current="page"{% endif %}>{{ t[lang].nav.home }}</a></li>
        <li><a href="{{ base }}{{ slugs.about }}/" {% if pageKey == "about" %}aria-current="page"{% endif %}>{{ t[lang].nav.about }}</a></li>
        <li><a href="{{ base }}{{ slugs.programs }}/" {% if pageKey == "programs" %}aria-current="page"{% endif %}>{{ t[lang].nav.programs }}</a></li>
        <li><a href="{{ base }}{{ slugs.autism }}/" {% if pageKey == "autism" %}aria-current="page"{% endif %}>{{ t[lang].nav.autism }}</a></li>
        <li><a href="{{ base }}{{ slugs.news }}/" {% if pageKey == "news" %}aria-current="page"{% endif %}>{{ t[lang].nav.news }}</a></li>
        <li><a href="{{ base }}{{ slugs.gallery }}/" {% if pageKey == "gallery" %}aria-current="page"{% endif %}>{{ t[lang].nav.gallery }}</a></li>
        <li><a href="{{ base }}{{ slugs.calendar }}/" {% if pageKey == "calendar" %}aria-current="page"{% endif %}>{{ t[lang].nav.calendar }}</a></li>
        <li><a href="{{ base }}{{ slugs.donate }}/" {% if pageKey == "donate" %}aria-current="page"{% endif %}>{{ t[lang].nav.donate }}</a></li>
        <li><a href="{{ base }}{{ slugs.contact }}/" {% if pageKey == "contact" %}aria-current="page"{% endif %}>{{ t[lang].nav.contact }}</a></li>
      </ul>
    </nav>

    <nav aria-label="{{ t[lang].a11y.langMenu }}">
      <ul class="lang-switch">
        {%- for l in site.languages %}
        <li>
          {%- if l.code == lang %}
          <span aria-current="true" lang="{{ l.code }}">{{ l.code | upper }}</span>
          {%- else %}
          <a href="{{ paths[l.code] }}" lang="{{ l.code }}" hreflang="{{ l.code }}">{{ l.code | upper }}<span class="visually-hidden"> — {{ l.label }}</span></a>
          {%- endif %}
        </li>
        {%- endfor %}
      </ul>
    </nav>
  </div>
</header>
