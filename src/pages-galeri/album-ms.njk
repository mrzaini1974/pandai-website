---
layout: layouts/base.njk
pageKey: gallery
lang: ms
dirAttr: ltr
base: /
pagination:
  data: collections.galeri
  size: 1
  alias: album
permalink: "/galeri/{{ album.fileSlug }}/index.html"
eleventyComputed:
  title: '{{ album.data["title_ms"] or album.data.title }}'
  paths:
    ms: "/galeri/{{ album.fileSlug }}/"
    en: "/en/galeri/{{ album.fileSlug }}/"
    ar: "/ar/galeri/{{ album.fileSlug }}/"
---
{% set albumTitle = album.data["title_ms"] or album.data.title %}
<section class="section">
  <div class="container">
    <p><a href="{{ base }}{{ slugs.gallery }}/">← {{ t[lang].gallery.title }}</a></p>
    <div class="section-head">
      <h1>{{ albumTitle }}</h1>
      <p class="post-meta"><time datetime="{{ album.date | dateISO }}">{{ album.date | dateDisplay(lang) }}</time></p>
      {% if album.data["desc_ms"] %}<p class="lead">{{ album.data["desc_ms"] }}</p>{% endif %}
    </div>
    <div class="gallery-grid">
      {% for img in album.data.images %}
      <img src="{{ img.src }}" alt="{{ img.alt }}" loading="lazy">
      {% endfor %}
    </div>
  </div>
</section>
