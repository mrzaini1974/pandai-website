---
pageKey: home
pageSlug: ""
---
{% set s = t[lang].home %}

<section class="hero">
  <div class="container">
    <p class="kicker">{{ s.heroKicker }}</p>
    <h1>{{ s.heroTitle }}</h1>
    <p class="hero-lead">{{ s.heroLead }}</p>
    <div class="hero-ctas">
      <a class="btn btn--gold" href="{{ base }}{{ slugs.donate }}/">{{ s.ctaDonate }}</a>
      <a class="btn btn--outline" href="{{ base }}{{ slugs.programs }}/">{{ s.ctaPrograms }}</a>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head">
      <h2>{{ s.introTitle }}</h2>
      <p class="lead">{{ s.introText }}</p>
    </div>
  </div>
</section>

<section class="section section--alt">
  <div class="container">
    <div class="section-head">
      <h2>{{ s.focusTitle }}</h2>
      <p class="lead">{{ s.focusLead }}</p>
    </div>
    <div class="grid grid--4">
      {% for f in s.focus %}
      <div class="card">
        <span class="card-num" aria-hidden="true">{{ loop.index }}</span>
        <h3>{{ f.title }}</h3>
        <p>{{ f.desc }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="cta-band">
      <h2>{{ s.autismTitle }}</h2>
      <p>{{ s.autismLead }}</p>
      <p class="mt-2"><a class="btn btn--gold" href="{{ base }}{{ slugs.autism }}/">{{ s.autismCta }}</a></p>
    </div>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="section-head">
      <h2>{{ s.newsTitle }}</h2>
    </div>
    {% set posts = collections["berita_" + lang] %}
    {% if posts.length %}
    <div class="grid grid--3">
      {% for post in posts | limit(3) %}
      <article class="post-card">
        {% if post.data.image %}<img src="{{ post.data.image }}" alt="{{ post.data.imageAlt or post.data.title }}" loading="lazy">{% endif %}
        <div class="post-card-body">
          <time datetime="{{ post.date | dateISO }}">{{ post.date | dateDisplay(lang) }}</time>
          <h3><a href="{{ post.url }}">{{ post.data.title }}</a></h3>
          <p>{{ post.data.excerpt }}</p>
        </div>
      </article>
      {% endfor %}
    </div>
    {% else %}
    <p>{{ t[lang].news.empty }}</p>
    {% endif %}
    <p class="mt-2"><a class="btn btn--navy" href="{{ base }}{{ slugs.news }}/">{{ s.newsAll }}</a></p>
  </div>
</section>

<section class="section section--navy">
  <div class="container">
    <div class="section-head">
      <h2>{{ s.valuesTitle }}</h2>
    </div>
    <div class="values-strip">
      {% for v in s.values %}
      <div class="value-item">
        <h3>{{ v.name }}</h3>
        <p>{{ v.desc }}</p>
      </div>
      {% endfor %}
    </div>
  </div>
</section>
