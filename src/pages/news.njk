---
pageKey: news
tSection: news
pageSlug: berita
---
{% set s = t[lang].news %}

<section class="section">
  <div class="container">
    <div class="section-head">
      <h1>{{ s.title }}</h1>
      <p class="lead">{{ s.lead }}</p>
    </div>

    {% set posts = collections["berita_" + lang] %}
    {% if posts.length %}
    <div class="grid grid--3">
      {% for post in posts %}
      <article class="post-card">
        {% if post.data.image %}<img src="{{ post.data.image }}" alt="{{ post.data.imageAlt or post.data.title }}" loading="lazy">{% endif %}
        <div class="post-card-body">
          <time datetime="{{ post.date | dateISO }}">{{ post.date | dateDisplay(lang) }}</time>
          <h2><a href="{{ post.url }}">{{ post.data.title }}</a></h2>
          <p>{{ post.data.excerpt }}</p>
        </div>
      </article>
      {% endfor %}
    </div>
    {% else %}
    <p class="lead">{{ s.empty }}</p>
    {% endif %}
  </div>
</section>
